{
  "version": "1.0",
  "rules": [
        {
      "id": "toki_common",
      "name": "토끼 계열 (뉴토끼/마나토끼) 통합 규칙",
      "urlPattern": ".*(newtoki|manatoki|comic|booktoki).*",
      "category": "Webtoon",
      "meta": {
        "title": {
          "selector": "meta[name=\"subject\"]",
          "attr": "content"
        },
        "author": {
          "selector": ".view-content",
          "regex": "(?:작가|저자|글작가|글)\\s*:\\s*([^ \\n\\r,·/]+)"
        },
        "thumb": {
          "selector": "img[itemprop=\"image\"]",
          "attr": "src"
        },
        "status": {
          "selector": ".view-content",
          "regex": "(완결|연재중)"
        },
        "summary": {
          "selector": "meta[property=\"og:description\"]",
          "attr": "content"
        }
      },
      "list": {
        "container": ".list-body",
        "item": "li",
        "num": ".wr-num",
        "title": "a",
        "link": {
          "selector": "a",
          "attr": "href"
        }
      },
      "viewer": {
        "fetchMethod": "iframe",
        "keyDiscovery": {
          "regex": "data_attribute\\s*:\\s*['\"]([^'\"]+)['\"]",
          "prefix": "data-"
        },
        "imageRegex": "https?:\\\\/\\\\/[^\"' ]+\\\\.(?:jpg|png|webp)",
        "imageContainer": ".view-padding",
        "imageItem": "div img",
        "lazyAttrOptions": [
          "data-src",
          "data-original",
          "data-lazy",
          "data-url",
          "data-img"
        ],
        "seriesTitle": "meta[property=\"og:title\"]",
        "episodeTitle": "h1, .view-title",
        "novelContent": "#novel_content"
      }
    },
    {
      "id": "sbxh_webtoon",
      "name": "SBXH 웹툰 규칙",
      "urlPattern": ".*sbxh[0-9]*\\..*/webtoon/.*",
      "category": "Webtoon",
      "idExtraction": {
        "source": "url",
        "regex": "\\/webtoon\\/([0-9]+)" 
      },      
      "meta": {
        "title": "h1.hero-v2-title",
        "author": "div.hero-v2-author",
        "thumb": {
          "selector": "div.hero-v2-thumb > img",
          "attr": "src"
        },
        "status": "span.pill-status",
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.ep-list-v2",
        "item": "li.ep-row-v2",
        "num": "span.ep-row-v2-no",
        "title": ".ep-row-v2-title strong",
        "sub": {
          "selector": "span.sub",
          "regex": "\\[(.*?)\\]"
        },
        "link": {
          "selector": "a.ep-row-v2-link",
          "attr": "href"
        },
        "date": "span.ep-row-v2-date"
      },
      "viewer": {
        "fetchMethod": "iframe",
        "imageContainer": "div.vw-imgs",
        "imageItem": "img",
        "lazyAttrOptions": [
          "data-src",
          "data-lazy",
          "src"
        ]
      }
    },
    {
      "id": "sbxh_manhwa",
      "name": "SBXH 만화 규칙",
      "urlPattern": ".*sbxh[0-9]*\\..*/manhwa/.*", 
      "idExtraction": {
        "source": "url",
        "regex": "\\/manhwa\\/([0-9]+)" 
      },
      "category": "Manga",
      "meta": {
        "title": "h1.hero-v2-title",
        "author": "div.hero-v2-author",
        "thumb": {
          "selector": "div.hero-v2-thumb > img",
          "attr": "src"
        },
        "status": "span.pill-status",
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.ep-list-v2",
        "item": "li.ep-row-v2",
        "num": "span.ep-row-v2-no",
        "title": ".ep-row-v2-title strong",
        "sub": {
          "selector": "span.sub",
          "regex": "\\[(.*?)\\]"
        },
        "link": {
          "selector": "a.ep-row-v2-link",
          "attr": "href"
        },
        "date": "span.ep-row-v2-date"
      },
      "viewer": {
        "fetchMethod": "iframe",
        "imageContainer": "div.vw-imgs",
        "imageItem": "img",
        "lazyAttrOptions": [
          "data-src",
          "data-lazy",
          "src"
        ]
      }
    },
    {
      "id": "sbxh_novel",
      "name": "SBXH 소설 규칙",
      "urlPattern": ".*sbxh[0-9]*\\..*/novel/.*",
      "category": "Novel",
      "idExtraction": {
        "source": "url",
        "regex": "\\/novel\\/([0-9]+)" 
      },
      "meta": {
        "title": "div.nd-info > h1",
        "author": "div.nd-meta span:first-child",
        "thumb": {
          "selector": "div.nd-thumb img",
          "attr": "src"
        },
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.novel-eps",
        "item": "li",
        "num": "span.ne-num",
        "title": "span.ne-title",
        "sub": {
          "selector": "span.sub",
          "regex": "\\[(.*?)\\]"
        },
        "link": {
          "selector": "a",
          "attr": "href"
        },
        "date": "span.ne-date"
      },
      "viewer": {
        "fetchMethod": "api",
        "decryptApi": {
          "endpoint": "/api/novel-content",
          "cookieName": "nv",
          "clientHeader": "shadow-v2"
        },
        "seriesTitle": "div.crumb a:last-of-type",
        "episodeTitle": "h1.ne-h1",
        "episodeNum": "div.crumb strong",
        "novelContent": "article.novel-viewer",
        "imageContainer": "article.novel-viewer",
        "imageItem": "p",
        "lazyAttrOptions": []
      }
    }
  ]
}
