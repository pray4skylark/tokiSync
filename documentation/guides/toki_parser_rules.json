{
  "version": "1.26.4",
  "rules": [
    {
      "id": "toki_common",
      "name": "토끼 계열 (뉴토끼/마나토끼) 통합 규칙",
      "urlPattern": ".*(newtoki|manatoki|comic|booktoki).*",
      "category": "Webtoon",
      "meta": {
        "title": {
          "selector": "meta[name=\"subject\"]",
          "attr": "content"
        },
        "author": {
          "selector": ".view-content",
          "regex": "(?:작가|저자|글작가|글)\\s*:\\s*([^ \\n\\r,·/]+)"
        },
        "thumb": {
          "selector": "img[itemprop=\"image\"]",
          "attr": "src"
        },
        "status": {
          "selector": ".view-content",
          "regex": "(완결|연재중)"
        },
        "summary": {
          "selector": "meta[property=\"og:description\"]",
          "attr": "content"
        }
      },
      "list": {
        "container": ".list-body",
        "item": "li",
        "num": ".wr-num",
        "title": "a",
        "link": {
          "selector": "a",
          "attr": "href"
        }
      },
      "viewer": {
        "fetchMethod": "iframe",
        "keyDiscovery": {
          "regex": "data_attribute\\s*:\\s*['\"]([^'\"]+)['\"]",
          "prefix": "data-"
        },
        "imageRegex": "https?:\\\\/\\\\/[^\"' ]+\\\\.(?:jpg|png|webp)",
        "imageContainer": ".view-padding",
        "imageItem": "div img",
        "lazyAttrOptions": [
          "data-src",
          "data-original",
          "data-lazy",
          "data-url",
          "data-img"
        ],
        "seriesTitle": "meta[property=\"og:title\"]",
        "episodeTitle": "h1, .view-title",
        "novelContent": "#novel_content"
      }
    }
  ]
}
